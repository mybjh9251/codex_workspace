<Window x:Class="NuGetDependencyDownloaderWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NuGet Dependency Downloader" Height="620" Width="980"
        PreviewMouseDown="Window_PreviewMouseDown"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F5F5F7"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#E5E5EA"/>
        <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#F2F2F4"/>
        <SolidColorBrush x:Key="ButtonPressedBrush" Color="#E8E8ED"/>
        <SolidColorBrush x:Key="TableHeaderBrush" Color="#F5F5F7"/>
        <SolidColorBrush x:Key="ProgressTrackBrush" Color="#E8E8ED"/>
        <SolidColorBrush x:Key="SuggestionHoverBrush" Color="#EEF5FF"/>
        <SolidColorBrush x:Key="SuggestionSelectedBrush" Color="#DCEBFF"/>
        <SolidColorBrush x:Key="ControlBorderBrush" Color="#D2D2D7"/>
        <SolidColorBrush x:Key="ControlHoverBorderBrush" Color="#A7A7AD"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#007AFF"/>
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#006EDB"/>
        <SolidColorBrush x:Key="TextBrush" Color="#1D1D1F"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6E6E73"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="9,4"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource ControlHoverBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="78"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ButtonPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{DynamicResource TableHeaderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>

        <Style x:Key="AppleProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ButtonPressedBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5"/>
                            <Border x:Name="PART_Track" CornerRadius="5"/>
                            <Decorator x:Name="PART_Indicator"
                                       HorizontalAlignment="Left">
                                <Border Background="{TemplateBinding Foreground}" CornerRadius="5"/>
                            </Decorator>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuggestionListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style x:Key="SuggestionItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border" Background="Transparent" CornerRadius="6">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource SuggestionHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource SuggestionSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="14" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="12">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Package Id" Margin="0,0,8,0"/>
            <Grid Grid.Column="1" Margin="0,0,12,0">
                <TextBox x:Name="PackageIdTextBox"
                         Text="{Binding PackageIdInput, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="PackageIdTextBox_GotFocus"/>
                <Popup x:Name="PackageIdSuggestionsPopup"
                       PlacementTarget="{Binding Source={x:Reference PackageIdTextBox}}"
                       Placement="Bottom"
                       IsOpen="{Binding IsPackageIdSuggestionsOpen, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       StaysOpen="True"
                       AllowsTransparency="True"
                       Closed="PackageIdSuggestionsPopup_Closed">
                    <Border Width="{Binding ActualWidth, Source={x:Reference PackageIdTextBox}}"
                            MaxHeight="220"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <ListBox ItemsSource="{Binding PackageIdSuggestions}"
                                 Style="{StaticResource SuggestionListBoxStyle}"
                                 ItemContainerStyle="{StaticResource SuggestionItemStyle}"
                                 SelectionChanged="PackageIdSuggestion_SelectionChanged"
                                 KeyboardNavigation.TabNavigation="Cycle"/>
                    </Border>
                </Popup>
            </Grid>
            <TextBlock Grid.Column="2" Text="Version" Margin="0,0,8,0"/>
            <Grid Grid.Column="3" Margin="0,0,12,0">
                <TextBox x:Name="PackageVersionTextBox"
                         Text="{Binding VersionInput, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="PackageVersionTextBox_GotFocus"/>
                <Popup x:Name="VersionSuggestionsPopup"
                       PlacementTarget="{Binding Source={x:Reference PackageVersionTextBox}}"
                       Placement="Bottom"
                       IsOpen="{Binding IsVersionSuggestionsOpen, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       StaysOpen="True"
                       AllowsTransparency="True"
                       Closed="VersionSuggestionsPopup_Closed">
                    <Border Width="{Binding ActualWidth, Source={x:Reference PackageVersionTextBox}}"
                            MaxHeight="220"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <ListBox ItemsSource="{Binding VersionSuggestions}"
                                 Style="{StaticResource SuggestionListBoxStyle}"
                                 ItemContainerStyle="{StaticResource SuggestionItemStyle}"
                                 SelectionChanged="VersionSuggestion_SelectionChanged"
                                 KeyboardNavigation.TabNavigation="Cycle"/>
                    </Border>
                </Popup>
            </Grid>
            <TextBlock Grid.Column="4" Text="Target" Margin="0,0,8,0"/>
            <TextBox x:Name="TargetFrameworkTextBox" Grid.Column="5" Text="{Binding TargetFramework, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
            <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Theme" Margin="0,0,8,0"/>
                <ComboBox x:Name="ThemeComboBox" Width="92" Height="30" Margin="0,0,12,0" SelectedIndex="0" SelectionChanged="ThemeComboBox_SelectionChanged">
                    <ComboBoxItem Content="Light"/>
                    <ComboBoxItem Content="Black"/>
                </ComboBox>
                <Button Content="Add" Width="70" Margin="0,0,8,0" Click="AddPackage_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                <Button Content="Remove" Width="80" Click="RemovePackage_Click"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="NuGet Source" Margin="0,0,8,0"/>
            <TextBox Grid.Column="1" Text="{Binding PackageSource, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
            <TextBlock Grid.Column="2" Text="Retries" Margin="0,0,8,0"/>
            <TextBox Grid.Column="3" Text="{Binding RetryCount, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Output Folder" Margin="0,0,8,0"/>
            <TextBox Grid.Column="1" Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
            <Button Grid.Column="2" Content="Browse" Width="80" Margin="0,0,12,0" Click="BrowseOutputFolder_Click"/>
            <CheckBox Grid.Column="3" Content="Overwrite" IsChecked="{Binding OverwriteExisting}" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <Button Grid.Column="4" Content="Import List" Margin="0,0,8,0" Click="ImportPackageList_Click"/>
            <Button Grid.Column="5" Content="Export List" Width="100" Click="ExportPackageList_Click"/>
        </Grid>

        <ListView x:Name="PackageListView" Grid.Row="3" ItemsSource="{Binding Packages}" SelectionMode="Single">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Package Id" DisplayMemberBinding="{Binding Id}" Width="260"/>
                    <GridViewColumn Header="Version" DisplayMemberBinding="{Binding Version}" Width="110"/>
                    <GridViewColumn Header="Kind" DisplayMemberBinding="{Binding Kind}" Width="100"/>
                    <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="110"/>
                    <GridViewColumn Header="Message" DisplayMemberBinding="{Binding Message}" Width="320"/>
                    <GridViewColumn Header="Progress" Width="260">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="8,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="46"/>
                                    </Grid.ColumnDefinitions>
                                    <ProgressBar Grid.Column="0"
                                                 Value="{Binding Progress}"
                                                 Maximum="100"
                                                 VerticalAlignment="Center"
                                                 Style="{StaticResource AppleProgressBarStyle}"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Progress, StringFormat={}{0}%}"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <TextBlock Grid.Row="4" Text="{Binding Summary}" Foreground="{DynamicResource MutedTextBrush}" Margin="0,8,0,8"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Retry Failed" Width="110" Height="30" Margin="0,0,8,0" Click="RetryFailed_Click"/>
            <Button Content="Cancel" Width="90" Height="30" Margin="0,0,8,0" Click="CancelDownload_Click"/>
            <Button Content="Start Download" Width="150" Height="30" Click="StartDownload_Click" Style="{StaticResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
    </Border>
</Window>

