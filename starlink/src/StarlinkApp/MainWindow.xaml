<Window x:Class="StarlinkApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:pages="clr-namespace:StarlinkApp.Views.Pages"
        mc:Ignorable="d"
        Title="StarlinkApp"
        Height="860"
        Width="1180"
        MinHeight="760"
        MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid Margin="30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Style="{StaticResource CardStyle}"
                Margin="0,0,28,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="SIMULATOR"
                               Style="{StaticResource CaptionTextStyle}" />
                    <TextBlock Text="Home vertical slice"
                               Margin="0,8,0,0"
                               Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Text="In-process simulator now, TCP server later."
                               Margin="0,8,0,0"
                               Style="{StaticResource MutedBodyTextStyle}" />
                </StackPanel>

                <ItemsControl Grid.Row="1"
                              Margin="0,28,0,0"
                              ItemsSource="{Binding Scenarios}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding DisplayName}"
                                    Command="{Binding DataContext.ChangeScenarioCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding Key}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,0,10" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Grid.Row="2"
                        Margin="0,20,0,0"
                        Padding="16"
                        Background="{StaticResource PanelBackgroundBrush}"
                        CornerRadius="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Activity log"
                                   Style="{StaticResource CaptionTextStyle}" />
                        <ItemsControl Grid.Row="1"
                                      Margin="0,14,0,0"
                                      ItemsSource="{Binding ActivityLog}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,10"
                                               Style="{StaticResource MutedBodyTextStyle}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1"
              HorizontalAlignment="Center">
            <Border Width="420"
                    Height="790"
                    Style="{StaticResource PhoneShellStyle}">
                <pages:HomePage />
            </Border>
        </Grid>
    </Grid>
</Window>
