<UserControl x:Class="StarlinkApp.Views.Pages.ObstructionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource PhoneBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="28,24,28,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="9:41"
                       Style="{StaticResource PhoneCaptionTextStyle}" />
            <TextBlock Grid.Column="1"
                       Text="LTE  Wi-Fi  Battery"
                       Style="{StaticResource PhoneCaptionTextStyle}" />
        </Grid>

        <StackPanel Grid.Row="1"
                    Margin="28,44,28,20">
            <TextBlock Text="OBSTRUCTIONS"
                       Style="{StaticResource PhoneCaptionTextStyle}" />
            <TextBlock Text="{Binding ObstructionStatusText}"
                       Margin="0,10,0,0"
                       Style="{StaticResource SectionTitleTextStyle}" />
            <TextBlock Text="{Binding ObstructionDetailText}"
                       Margin="0,10,0,0"
                       Style="{StaticResource MutedBodyTextStyle}" />

            <Grid Height="285"
                  Margin="0,34,0,0">
                <Ellipse Fill="{StaticResource BeamGlowBrush}"
                         Opacity="0.62" />
                <Ellipse Width="150"
                         Height="150"
                         Fill="{StaticResource PanelBackgroundBrush}"
                         Stroke="{StaticResource MutedBorderBrush}"
                         StrokeThickness="1"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
                <TextBlock Text="{Binding ObstructionPercentText}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Style="{StaticResource MetricTextStyle}" />
                <ItemsControl Width="178"
                              Height="178"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              ItemsSource="{Binding Cells}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="5"
                                         Columns="5" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="2"
                                    BorderBrush="{StaticResource MutedBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource ObstructionClearBrush}" />
                                        <Setter Property="Opacity" Value="0.72" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Level}" Value="1">
                                                <Setter Property="Background" Value="{StaticResource ObstructionPartialBrush}" />
                                                <Setter Property="Opacity" Value="0.9" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Level}" Value="2">
                                                <Setter Property="Background" Value="{StaticResource ObstructionHeavyBrush}" />
                                                <Setter Property="Opacity" Value="0.96" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Marker}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           FontWeight="SemiBold" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <TextBlock Text="{Binding ScanProgressText}"
                       Margin="0,12,0,0"
                       Style="{StaticResource PhoneCaptionTextStyle}" />
            <TextBlock Text="{Binding LastScanText}"
                       Margin="0,4,0,0"
                       Style="{StaticResource PhoneCaptionTextStyle}" />

            <Button Content="Check for obstructions"
                    Command="{Binding CheckObstructionsCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="0,30,0,0" />
        </StackPanel>

        <Border Grid.Row="2"
                Height="5"
                Width="160"
                Margin="0,0,0,14"
                HorizontalAlignment="Center"
                Background="{StaticResource PrimaryTextBrush}"
                CornerRadius="3" />
    </Grid>
</UserControl>
