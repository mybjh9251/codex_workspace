<UserControl x:Class="StarlinkApp.Views.Pages.ObstructionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource PhoneBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="28,24,28,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="9:41"
                       Style="{StaticResource PhoneCaptionTextStyle}" />
            <TextBlock Grid.Column="1"
                       Text="LTE  Wi-Fi  Battery"
                       Style="{StaticResource PhoneCaptionTextStyle}" />
        </Grid>

        <StackPanel Grid.Row="1"
                    Margin="28,34,28,20">
            <Button Content="&lt; Home"
                    Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="home"
                    Style="{StaticResource BackButtonStyle}" />

            <TextBlock Text="OBSTRUCTIONS"
                       Margin="0,18,0,0"
                       Style="{StaticResource PhoneCaptionTextStyle}" />
            <TextBlock Text="{Binding ObstructionStatusText}"
                       Margin="0,10,0,0"
                       Style="{StaticResource SectionTitleTextStyle}" />
            <TextBlock Text="{Binding ObstructionDetailText}"
                       Margin="0,10,0,0"
                       Style="{StaticResource MutedBodyTextStyle}" />

            <Grid Height="235"
                  Margin="0,22,0,0">
                <Ellipse Fill="{StaticResource BeamGlowBrush}"
                         Opacity="0.62" />
                <Ellipse Width="150"
                         Height="150"
                         Fill="{StaticResource PanelBackgroundBrush}"
                         Stroke="{StaticResource MutedBorderBrush}"
                         StrokeThickness="1"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
                <TextBlock Text="{Binding ObstructionPercentText}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Style="{StaticResource MetricTextStyle}" />
                <ItemsControl Width="178"
                              Height="178"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              ItemsSource="{Binding Cells}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="5"
                                         Columns="5" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.SelectCellCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource ObstructionCellButtonStyle}">
                                <Border Margin="2"
                                        BorderBrush="{StaticResource MutedBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource ObstructionClearBrush}" />
                                            <Setter Property="Opacity" Value="0.72" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Level}" Value="1">
                                                    <Setter Property="Background" Value="{StaticResource ObstructionPartialBrush}" />
                                                    <Setter Property="Opacity" Value="0.9" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="2">
                                                    <Setter Property="Background" Value="{StaticResource ObstructionHeavyBrush}" />
                                                    <Setter Property="Opacity" Value="0.96" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryTextBrush}" />
                                                    <Setter Property="BorderThickness" Value="2" />
                                                    <Setter Property="Opacity" Value="1" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Marker}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               FontWeight="SemiBold" />
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <TextBlock Text="{Binding ScanProgressText}"
                       Margin="0,12,0,0"
                       Style="{StaticResource PhoneCaptionTextStyle}" />
            <Border Width="220"
                    Height="6"
                    HorizontalAlignment="Left"
                    Margin="0,8,0,0"
                    Background="{StaticResource PanelBackgroundBrush}"
                    CornerRadius="3">
                <Border Width="{Binding ScanProgressBarWidth}"
                        HorizontalAlignment="Left"
                        Background="{StaticResource StarlinkBlueBrush}"
                        CornerRadius="3" />
            </Border>
            <TextBlock Text="{Binding LastScanText}"
                       Margin="0,4,0,0"
                       Style="{StaticResource PhoneCaptionTextStyle}" />

            <Border Margin="0,12,0,0"
                    Style="{StaticResource MetricCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding SelectedCellTitle}"
                               Style="{StaticResource RowTitleTextStyle}" />
                    <TextBlock Text="{Binding SelectedCellDetail}"
                               Margin="0,6,0,0"
                               Style="{StaticResource PhoneCaptionTextStyle}" />
                </StackPanel>
            </Border>

            <Button Content="{Binding ScanButtonText}"
                    Command="{Binding CheckObstructionsCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="0,18,0,0" />
        </StackPanel>

        <Border Grid.Row="2"
                Height="5"
                Width="160"
                Margin="0,0,0,14"
                HorizontalAlignment="Center"
                Background="{StaticResource PrimaryTextBrush}"
                CornerRadius="3" />
    </Grid>
</UserControl>
