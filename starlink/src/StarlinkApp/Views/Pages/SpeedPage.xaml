<UserControl x:Class="StarlinkApp.Views.Pages.SpeedPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource PhoneBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="28,24,28,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="9:41"
                       Style="{StaticResource PhoneCaptionTextStyle}" />
            <TextBlock Grid.Column="1"
                       Text="LTE  Wi-Fi  Battery"
                       Style="{StaticResource PhoneCaptionTextStyle}" />
        </Grid>

        <StackPanel Grid.Row="1"
                    Margin="28,34,28,20">
            <Button Content="&lt; Home"
                    Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="home"
                    Style="{StaticResource BackButtonStyle}" />

            <TextBlock Text="SPEED"
                       Margin="0,18,0,0"
                       Style="{StaticResource PhoneCaptionTextStyle}" />
            <TextBlock Text="{Binding DownloadText}"
                       Margin="0,10,0,0"
                       Style="{StaticResource HeroStatusTextStyle}" />
            <TextBlock Text="{Binding SpeedTargetText}"
                       Margin="0,4,0,0"
                       Style="{StaticResource MutedBodyTextStyle}" />

            <Border Margin="0,34,0,0"
                    Style="{StaticResource MetricCardStyle}">
                <StackPanel>
                    <TextBlock Text="Download"
                               Style="{StaticResource PhoneCaptionTextStyle}" />
                    <Border Width="180"
                            Height="8"
                            HorizontalAlignment="Left"
                            Margin="0,10,0,0"
                            Background="{StaticResource PanelBackgroundBrush}"
                            CornerRadius="4">
                        <Border Width="{Binding DownloadBarWidth, Mode=OneWay}"
                                HorizontalAlignment="Left"
                                Background="{StaticResource StarlinkBlueBrush}"
                                CornerRadius="4" />
                    </Border>

                    <TextBlock Text="Upload"
                               Margin="0,22,0,0"
                               Style="{StaticResource PhoneCaptionTextStyle}" />
                    <Border Width="180"
                            Height="8"
                            HorizontalAlignment="Left"
                            Margin="0,10,0,0"
                            Background="{StaticResource PanelBackgroundBrush}"
                            CornerRadius="4">
                        <Border Width="{Binding UploadBarWidth, Mode=OneWay}"
                                HorizontalAlignment="Left"
                                Background="{StaticResource OnlineBrush}"
                                CornerRadius="4" />
                    </Border>
                </StackPanel>
            </Border>

            <Grid Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource MetricCardStyle}"
                        Margin="0,0,7,0">
                    <StackPanel>
                        <TextBlock Text="Upload"
                                   Style="{StaticResource PhoneCaptionTextStyle}" />
                        <TextBlock Text="{Binding UploadText}"
                                   Margin="0,8,0,0"
                                   Style="{StaticResource MetricTextStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource MetricCardStyle}"
                        Margin="7,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Latency"
                                   Style="{StaticResource PhoneCaptionTextStyle}" />
                        <TextBlock Text="{Binding LatencyText}"
                                   Margin="0,8,0,0"
                                   Style="{StaticResource MetricTextStyle}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Button Content="Run advanced speed test"
                    Command="{Binding RunAdvancedSpeedTestCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="0,28,0,0" />
        </StackPanel>

        <Border Grid.Row="2"
                Height="5"
                Width="160"
                Margin="0,0,0,14"
                HorizontalAlignment="Center"
                Background="{StaticResource PrimaryTextBrush}"
                CornerRadius="3" />
    </Grid>
</UserControl>
