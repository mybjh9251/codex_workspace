<UserControl x:Class="StarlinkApp.Views.Pages.SetupPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource PhoneBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="28,24,28,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="9:41"
                       Style="{StaticResource PhoneCaptionTextStyle}" />
            <TextBlock Grid.Column="1"
                       Text="LTE  Wi-Fi  Battery"
                       Style="{StaticResource PhoneCaptionTextStyle}" />
        </Grid>

        <StackPanel Grid.Row="1"
                    Margin="28,34,28,20">
            <Button Content="&lt; Home"
                    Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="home"
                    Style="{StaticResource BackButtonStyle}" />

            <TextBlock Text="SETUP"
                       Margin="0,18,0,0"
                       Style="{StaticResource PhoneCaptionTextStyle}" />
            <TextBlock Text="{Binding SetupStepText}"
                       Margin="0,10,0,0"
                       Style="{StaticResource HeroStatusTextStyle}" />
            <TextBlock Text="{Binding SetupHintText}"
                       Margin="0,10,0,0"
                       Style="{StaticResource MutedBodyTextStyle}" />

            <Border Margin="0,34,0,0"
                    Style="{StaticResource MetricCardStyle}">
                <StackPanel>
                    <TextBlock Text="1  Plug in Starlink"
                               Style="{StaticResource RowTitleTextStyle}" />
                    <TextBlock Text="2  Find a clear view"
                               Margin="0,18,0,0"
                               Style="{StaticResource RowTitleTextStyle}" />
                    <TextBlock Text="3  Connect to Wi-Fi"
                               Margin="0,18,0,0"
                               Style="{StaticResource RowTitleTextStyle}" />
                </StackPanel>
            </Border>

            <Button Content="Continue setup"
                    Command="{Binding ContinueSetupCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="0,34,0,0" />
        </StackPanel>

        <Border Grid.Row="2"
                Height="5"
                Width="160"
                Margin="0,0,0,14"
                HorizontalAlignment="Center"
                Background="{StaticResource PrimaryTextBrush}"
                CornerRadius="3" />
    </Grid>
</UserControl>
