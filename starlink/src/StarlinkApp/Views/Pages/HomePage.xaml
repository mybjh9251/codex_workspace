<UserControl x:Class="StarlinkApp.Views.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource PhoneBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="28,24,28,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="9:41"
                       Style="{StaticResource PhoneCaptionTextStyle}" />
            <TextBlock Grid.Column="1"
                       Text="LTE  Wi-Fi  Battery"
                       Style="{StaticResource PhoneCaptionTextStyle}" />
        </Grid>

        <Grid Grid.Row="1"
              Margin="28,36,28,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                    <TextBlock Text="{Binding AccountName}"
                           Style="{StaticResource PhoneCaptionTextStyle}" />

                <StackPanel Orientation="Horizontal"
                            Margin="0,6,0,0">
                    <TextBlock Text="{Binding StatusTitle}"
                               Style="{StaticResource HeroStatusTextStyle}" />
                    <Ellipse Width="10"
                             Height="10"
                             Margin="10,26,0,0"
                             Fill="{StaticResource OnlineBrush}" />
                </StackPanel>

                <TextBlock Text="{Binding StatusSubtitle}"
                           Margin="0,4,0,0"
                           Style="{StaticResource MutedBodyTextStyle}" />
            </StackPanel>

            <Grid Grid.Row="1">
                <Ellipse Width="260"
                         Height="260"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Top"
                         Margin="0,26,0,0"
                         Fill="{StaticResource BeamGlowBrush}"
                         Opacity="0.78" />

                <Polygon Points="130,30 245,86 150,136 38,78"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Top"
                         Margin="0,126,0,0"
                         Fill="{StaticResource DishBrush}"
                         Stroke="{StaticResource MutedBorderBrush}"
                         StrokeThickness="1" />

                <Rectangle Width="5"
                           Height="118"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           Margin="0,238,0,0"
                           Fill="{StaticResource MutedBorderBrush}" />
            </Grid>

            <StackPanel Grid.Row="2">
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource MetricCardStyle}"
                            Margin="0,0,7,0">
                        <StackPanel>
                            <TextBlock Text="Ping success"
                                       Style="{StaticResource PhoneCaptionTextStyle}" />
                            <TextBlock Text="{Binding PingSuccessText}"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource MetricTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource MetricCardStyle}"
                            Margin="7,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Latency"
                                       Style="{StaticResource PhoneCaptionTextStyle}" />
                            <TextBlock Text="{Binding LatencyText}"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource MetricTextStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Button Command="{Binding NavigateCommand}"
                        CommandParameter="setup"
                        Style="{StaticResource NavigationRowButtonStyle}">
                    <Grid>
                        <TextBlock Text="Setup"
                                   Style="{StaticResource RowTitleTextStyle}" />
                        <TextBlock HorizontalAlignment="Right"
                                   Text=">"
                                   Style="{StaticResource RowTitleTextStyle}" />
                    </Grid>
                </Button>

                <Button Command="{Binding NavigateCommand}"
                        CommandParameter="statistics"
                        Style="{StaticResource NavigationRowButtonStyle}">
                    <Grid>
                        <TextBlock Text="Statistics"
                                   Style="{StaticResource RowTitleTextStyle}" />
                        <TextBlock HorizontalAlignment="Right"
                                   Text=">"
                                   Style="{StaticResource RowTitleTextStyle}" />
                    </Grid>
                </Button>

                <Button Command="{Binding NavigateCommand}"
                        CommandParameter="network"
                        Style="{StaticResource NavigationRowButtonStyle}">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Network"
                                       Style="{StaticResource RowTitleTextStyle}" />
                            <TextBlock Text="{Binding DeviceCountText}"
                                       Style="{StaticResource PhoneCaptionTextStyle}" />
                        </StackPanel>
                        <TextBlock HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Text=">"
                                   Style="{StaticResource RowTitleTextStyle}" />
                    </Grid>
                </Button>

                <Button Command="{Binding NavigateCommand}"
                        CommandParameter="obstructions"
                        Style="{StaticResource NavigationRowButtonStyle}">
                    <Grid>
                        <TextBlock Text="Obstructions"
                                   Style="{StaticResource RowTitleTextStyle}" />
                        <TextBlock HorizontalAlignment="Right"
                                   Text=">"
                                   Style="{StaticResource RowTitleTextStyle}" />
                    </Grid>
                </Button>

                <Button Command="{Binding NavigateCommand}"
                        CommandParameter="speed"
                        Style="{StaticResource NavigationRowButtonStyle}">
                    <Grid>
                        <TextBlock Text="Speed"
                                   Style="{StaticResource RowTitleTextStyle}" />
                        <TextBlock HorizontalAlignment="Right"
                                   Text=">"
                                   Style="{StaticResource RowTitleTextStyle}" />
                    </Grid>
                </Button>

                <Button Command="{Binding NavigateCommand}"
                        CommandParameter="advancedSpeed"
                        Style="{StaticResource NavigationRowButtonStyle}">
                    <Grid>
                        <TextBlock Text="Advanced Speed"
                                   Style="{StaticResource RowTitleTextStyle}" />
                        <TextBlock HorizontalAlignment="Right"
                                   Text=">"
                                   Style="{StaticResource RowTitleTextStyle}" />
                    </Grid>
                </Button>

                <Button Command="{Binding NavigateCommand}"
                        CommandParameter="settings"
                        Style="{StaticResource NavigationRowButtonStyle}">
                    <Grid>
                        <TextBlock Text="Settings"
                                   Style="{StaticResource RowTitleTextStyle}" />
                        <TextBlock HorizontalAlignment="Right"
                                   Text=">"
                                   Style="{StaticResource RowTitleTextStyle}" />
                    </Grid>
                </Button>

                <Button Content="{Binding PrimaryActionLabel}"
                        Command="{Binding PrimaryActionCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,18,0,0" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Height="5"
                Width="160"
                Margin="0,0,0,14"
                HorizontalAlignment="Center"
                Background="{StaticResource PrimaryTextBrush}"
                CornerRadius="3" />
    </Grid>
</UserControl>
