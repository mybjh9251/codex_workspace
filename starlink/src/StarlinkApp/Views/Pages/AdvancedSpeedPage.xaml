<UserControl x:Class="StarlinkApp.Views.Pages.AdvancedSpeedPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource PhoneBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="28,24,28,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="9:41"
                       Style="{StaticResource PhoneCaptionTextStyle}" />
            <TextBlock Grid.Column="1"
                       Text="LTE  Wi-Fi  Battery"
                       Style="{StaticResource PhoneCaptionTextStyle}" />
        </Grid>

        <ScrollViewer Grid.Row="1"
                      Margin="28,40,28,20"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="ADVANCED SPEED"
                           Style="{StaticResource PhoneCaptionTextStyle}" />
                <TextBlock Text="{Binding StatusText}"
                           Margin="0,10,0,0"
                           Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock Text="{Binding TargetDeviceName}"
                           Margin="0,6,0,0"
                           Style="{StaticResource MutedBodyTextStyle}" />

                <Grid Margin="0,24,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource MetricCardStyle}"
                            Margin="0,0,7,10">
                        <StackPanel>
                            <TextBlock Text="Download"
                                       Style="{StaticResource PhoneCaptionTextStyle}" />
                            <TextBlock Text="{Binding DownloadText}"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource MetricTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource MetricCardStyle}"
                            Margin="7,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Upload"
                                       Style="{StaticResource PhoneCaptionTextStyle}" />
                            <TextBlock Text="{Binding UploadText}"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource MetricTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Style="{StaticResource MetricCardStyle}"
                            Margin="0,0,7,0">
                        <StackPanel>
                            <TextBlock Text="Latency"
                                       Style="{StaticResource PhoneCaptionTextStyle}" />
                            <TextBlock Text="{Binding LatencyText}"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource MetricTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource MetricCardStyle}"
                            Margin="7,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Jitter"
                                       Style="{StaticResource PhoneCaptionTextStyle}" />
                            <TextBlock Text="{Binding JitterText}"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource MetricTextStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Margin="0,24,0,0"
                        Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Chart"
                                   Style="{StaticResource PhoneCaptionTextStyle}" />
                        <ItemsControl Margin="0,12,0,0"
                                      ItemsSource="{Binding SampleBars}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Label}"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource PhoneCaptionTextStyle}" />
                                        <StackPanel Grid.Column="1">
                                            <Border Width="{Binding DownloadBarWidth}"
                                                    Height="7"
                                                    HorizontalAlignment="Left"
                                                    Background="{StaticResource StarlinkBlueBrush}"
                                                    CornerRadius="4" />
                                            <Border Width="{Binding UploadBarWidth}"
                                                    Height="5"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,4,0,0"
                                                    Background="{StaticResource OnlineBrush}"
                                                    CornerRadius="3" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <TextBlock Text="Path"
                           Margin="0,26,0,10"
                           Style="{StaticResource PhoneCaptionTextStyle}" />
                <ItemsControl ItemsSource="{Binding Segments}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource MetricCardStyle}"
                                    Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               Style="{StaticResource RowTitleTextStyle}" />
                                    <TextBlock Text="{Binding Description}"
                                               Margin="0,4,0,0"
                                               Style="{StaticResource PhoneCaptionTextStyle}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Style="{StaticResource PhoneCaptionTextStyle}">
                                        <Run Text="{Binding DownloadMbps, StringFormat={}{0:0.0} Mbps down}" />
                                        <Run Text="  /  " />
                                        <Run Text="{Binding LatencyMs, StringFormat={}{0} ms}" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Content="Run advanced speed test"
                        Command="{Binding RunAdvancedSpeedTestCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,18,0,0" />
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Height="5"
                Width="160"
                Margin="0,0,0,14"
                HorizontalAlignment="Center"
                Background="{StaticResource PrimaryTextBrush}"
                CornerRadius="3" />
    </Grid>
</UserControl>
