<UserControl x:Class="StarlinkApp.Views.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource PhoneBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="28,24,28,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="9:41"
                       Style="{StaticResource PhoneCaptionTextStyle}" />
            <TextBlock Grid.Column="1"
                       Text="LTE  Wi-Fi  Battery"
                       Style="{StaticResource PhoneCaptionTextStyle}" />
        </Grid>

        <ScrollViewer Grid.Row="1"
                      Margin="28,46,28,20"
                      VerticalScrollBarVisibility="Hidden">
            <StackPanel>
                <Button Content="&lt; Home"
                        Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="home"
                        Style="{StaticResource BackButtonStyle}" />

                <TextBlock Text="SETTINGS"
                           Margin="0,18,0,0"
                           Style="{StaticResource PhoneCaptionTextStyle}" />
                <TextBlock Text="Runtime configuration"
                           Margin="0,10,0,0"
                           Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock Text="These values are loaded from settings.json or the built-in fallback."
                           Margin="0,8,0,0"
                           Style="{StaticResource MutedBodyTextStyle}" />

                <Border Margin="0,28,0,0"
                        Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Account"
                                   Style="{StaticResource PhoneCaptionTextStyle}" />
                        <TextBox Text="{Binding AccountNameInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource PhoneTextBoxStyle}"
                                 Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Default scenario"
                                   Style="{StaticResource PhoneCaptionTextStyle}" />
                        <TextBox Text="{Binding DefaultScenarioInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource PhoneTextBoxStyle}"
                                 Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Refresh interval"
                                   Style="{StaticResource PhoneCaptionTextStyle}" />
                        <TextBox Text="{Binding RefreshIntervalInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource PhoneTextBoxStyle}"
                                 Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <CheckBox Content="Enable file logging"
                                  IsChecked="{Binding EnableFileLogging, Mode=TwoWay}" />
                        <TextBlock Text="Logging changes apply after restart."
                                   Margin="0,8,0,0"
                                   Style="{StaticResource PhoneCaptionTextStyle}" />
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Simulator mode"
                                   Style="{StaticResource PhoneCaptionTextStyle}" />
                        <TextBox Text="{Binding SimulatorModeInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource PhoneTextBoxStyle}"
                                 Margin="0,8,0,0" />
                        <TextBlock Text="Use InProcess or Tcp."
                                   Margin="0,8,0,0"
                                   Style="{StaticResource PhoneCaptionTextStyle}" />
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Simulator endpoint"
                                   Style="{StaticResource PhoneCaptionTextStyle}" />
                        <TextBox Text="{Binding SimulatorEndpointInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource PhoneTextBoxStyle}"
                                 Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Current simulator"
                                   Style="{StaticResource PhoneCaptionTextStyle}" />
                        <TextBlock Text="{Binding CurrentScenarioText}"
                                   Margin="0,6,0,0"
                                   Style="{StaticResource RowTitleTextStyle}" />
                        <TextBlock Text="{Binding ConnectionStateText}"
                                   Margin="0,4,0,0"
                                   Style="{StaticResource PhoneCaptionTextStyle}" />
                    </StackPanel>
                </Border>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource MetricCardStyle}"
                            Margin="0,0,7,0">
                        <StackPanel>
                            <TextBlock Text="Logging"
                                       Style="{StaticResource PhoneCaptionTextStyle}" />
                            <TextBlock Text="{Binding EnableFileLogging}"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource RowTitleTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource MetricCardStyle}"
                            Margin="7,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Scenarios"
                                       Style="{StaticResource PhoneCaptionTextStyle}" />
                            <TextBlock Text="{Binding ScenarioCountText}"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource RowTitleTextStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Button Content="Save settings"
                        Command="{Binding SaveSettingsCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="0,18,0,0" />
                <TextBlock Text="{Binding SaveStatusText}"
                           Margin="0,10,0,0"
                           TextWrapping="Wrap"
                           Style="{StaticResource PhoneCaptionTextStyle}" />
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Height="5"
                Width="160"
                Margin="0,0,0,14"
                HorizontalAlignment="Center"
                Background="{StaticResource PrimaryTextBrush}"
                CornerRadius="3" />
    </Grid>
</UserControl>
