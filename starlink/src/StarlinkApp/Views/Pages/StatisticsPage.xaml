<UserControl x:Class="StarlinkApp.Views.Pages.StatisticsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource PhoneBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="28,24,28,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="9:41"
                       Style="{StaticResource PhoneCaptionTextStyle}" />
            <TextBlock Grid.Column="1"
                       Text="LTE  Wi-Fi  Battery"
                       Style="{StaticResource PhoneCaptionTextStyle}" />
        </Grid>

        <ScrollViewer Grid.Row="1"
                      Margin="28,34,28,20"
                      VerticalScrollBarVisibility="Hidden">
            <StackPanel>
                <Button Content="&lt; Home"
                        Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="home"
                        Style="{StaticResource BackButtonStyle}" />

                <TextBlock Text="STATISTICS"
                           Margin="0,18,0,0"
                           Style="{StaticResource PhoneCaptionTextStyle}" />
                <TextBlock Text="{Binding StateText}"
                           Margin="0,10,0,0"
                           Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock Text="{Binding SummaryText}"
                           Margin="0,8,0,0"
                           Style="{StaticResource MutedBodyTextStyle}" />

                <Grid Margin="0,26,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource MetricCardStyle}"
                            Margin="0,0,7,10">
                        <StackPanel>
                            <TextBlock Text="Ping success"
                                       Style="{StaticResource PhoneCaptionTextStyle}" />
                            <TextBlock Text="{Binding PingSuccessText}"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource MetricTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource MetricCardStyle}"
                            Margin="7,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Latency"
                                       Style="{StaticResource PhoneCaptionTextStyle}" />
                            <TextBlock Text="{Binding LatencyText}"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource MetricTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Style="{StaticResource MetricCardStyle}"
                            Margin="0,0,7,10">
                        <StackPanel>
                            <TextBlock Text="Download"
                                       Style="{StaticResource PhoneCaptionTextStyle}" />
                            <TextBlock Text="{Binding DownloadText}"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource MetricTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource MetricCardStyle}"
                            Margin="7,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Upload"
                                       Style="{StaticResource PhoneCaptionTextStyle}" />
                            <TextBlock Text="{Binding UploadText}"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource MetricTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Style="{StaticResource MetricCardStyle}"
                            Margin="0,0,7,0">
                        <StackPanel>
                            <TextBlock Text="Devices"
                                       Style="{StaticResource PhoneCaptionTextStyle}" />
                            <TextBlock Text="{Binding DevicesText}"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource RowTitleTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Grid.Column="1"
                            Style="{StaticResource MetricCardStyle}"
                            Margin="7,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Sky view"
                                       Style="{StaticResource PhoneCaptionTextStyle}" />
                            <TextBlock Text="{Binding ObstructionText}"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource RowTitleTextStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Margin="0,18,0,0"
                        Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Scenario"
                                   Style="{StaticResource PhoneCaptionTextStyle}" />
                        <TextBlock Text="{Binding ScenarioText}"
                                   Margin="0,8,0,0"
                                   Style="{StaticResource RowTitleTextStyle}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Height="5"
                Width="160"
                Margin="0,0,0,14"
                HorizontalAlignment="Center"
                Background="{StaticResource PrimaryTextBrush}"
                CornerRadius="3" />
    </Grid>
</UserControl>
