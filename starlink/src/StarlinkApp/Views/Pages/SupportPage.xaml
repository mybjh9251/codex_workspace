<UserControl x:Class="StarlinkApp.Views.Pages.SupportPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource PhoneBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="28,24,28,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="9:41"
                       Style="{StaticResource PhoneCaptionTextStyle}" />
            <TextBlock Grid.Column="1"
                       Text="LTE  Wi-Fi  Battery"
                       Style="{StaticResource PhoneCaptionTextStyle}" />
        </Grid>

        <ScrollViewer Grid.Row="1"
                      Margin="28,44,28,20"
                      VerticalScrollBarVisibility="Hidden">
            <StackPanel>
                <Button Content="&lt; Home"
                        Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="home"
                        Style="{StaticResource BackButtonStyle}" />

                <TextBlock Text="SUPPORT"
                           Margin="0,18,0,0"
                           Style="{StaticResource PhoneCaptionTextStyle}" />
                <TextBlock Text="Troubleshooting"
                           Margin="0,10,0,0"
                           Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock Text="Local simulator guidance based on the current app state."
                           Margin="0,8,0,0"
                           Style="{StaticResource MutedBodyTextStyle}" />

                <ItemsControl Margin="0,28,0,0"
                              ItemsSource="{Binding SupportCards}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource MetricCardStyle}"
                                    Margin="0,0,0,12">
                                <TextBlock Text="{Binding}"
                                           TextWrapping="Wrap"
                                           Style="{StaticResource RowTitleTextStyle}" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Margin="0,16,0,0"
                        Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Feedback"
                                   Style="{StaticResource PhoneCaptionTextStyle}" />
                        <TextBox Text="{Binding FeedbackText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource PhoneTextBoxStyle}"
                                 Margin="0,10,0,0"
                                 MinHeight="82"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True" />
                        <Button Content="Submit feedback"
                                Command="{Binding SubmitFeedbackCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0,16,0,0" />
                        <TextBlock Text="{Binding SubmitStatusText}"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource PhoneCaptionTextStyle}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Height="5"
                Width="160"
                Margin="0,0,0,14"
                HorizontalAlignment="Center"
                Background="{StaticResource PrimaryTextBrush}"
                CornerRadius="3" />
    </Grid>
</UserControl>
