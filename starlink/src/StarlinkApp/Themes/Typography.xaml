<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="PhoneCaptionTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="CaptionTextStyle" BasedOn="{StaticResource PhoneCaptionTextStyle}" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
    </Style>

    <Style x:Key="MutedBodyTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        <Setter Property="FontFamily" Value="Bahnschrift" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="LineHeight" Value="19" />
    </Style>

    <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="FontFamily" Value="Bahnschrift SemiBold" />
        <Setter Property="FontSize" Value="24" />
    </Style>

    <Style x:Key="HeroStatusTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed" />
        <Setter Property="FontSize" Value="46" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style x:Key="MetricTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="FontFamily" Value="Bahnschrift SemiBold" />
        <Setter Property="FontSize" Value="22" />
    </Style>

    <Style x:Key="RowTitleTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        <Setter Property="FontFamily" Value="Bahnschrift SemiBold" />
        <Setter Property="FontSize" Value="15" />
    </Style>
</ResourceDictionary>
