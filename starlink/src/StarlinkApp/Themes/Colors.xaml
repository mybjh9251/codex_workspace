<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AppBackgroundColor">#050505</Color>
    <Color x:Key="PhoneBackgroundColor">#020303</Color>
    <Color x:Key="PanelBackgroundColor">#151515</Color>
    <Color x:Key="CardBackgroundColor">#1D1D1D</Color>
    <Color x:Key="PrimaryTextColor">#F7F7F2</Color>
    <Color x:Key="MutedTextColor">#8F9290</Color>
    <Color x:Key="MutedBorderColor">#3A3A3A</Color>
    <Color x:Key="OnlineColor">#62E67A</Color>
    <Color x:Key="StarlinkBlueColor">#3E85FF</Color>
    <Color x:Key="ObstructionClearColor">#163127</Color>
    <Color x:Key="ObstructionPartialColor">#A97926</Color>
    <Color x:Key="ObstructionHeavyColor">#D44B3A</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="PhoneBackgroundBrush" Color="{StaticResource PhoneBackgroundColor}" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="MutedBorderBrush" Color="{StaticResource MutedBorderColor}" />
    <SolidColorBrush x:Key="OnlineBrush" Color="{StaticResource OnlineColor}" />
    <SolidColorBrush x:Key="StarlinkBlueBrush" Color="{StaticResource StarlinkBlueColor}" />
    <SolidColorBrush x:Key="ObstructionClearBrush" Color="{StaticResource ObstructionClearColor}" />
    <SolidColorBrush x:Key="ObstructionPartialBrush" Color="{StaticResource ObstructionPartialColor}" />
    <SolidColorBrush x:Key="ObstructionHeavyBrush" Color="{StaticResource ObstructionHeavyColor}" />

    <LinearGradientBrush x:Key="BeamGlowBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F7F7F2" Offset="0" />
        <GradientStop Color="#323232" Offset="0.38" />
        <GradientStop Color="#020303" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="DishBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F2F2ED" Offset="0" />
        <GradientStop Color="#A8A8A2" Offset="0.55" />
        <GradientStop Color="#4D4D4D" Offset="1" />
    </LinearGradientBrush>
</ResourceDictionary>
