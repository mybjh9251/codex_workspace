<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Padding" Value="{StaticResource CardPadding}" />
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}" />
        <Setter Property="BorderBrush" Value="{StaticResource MutedBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="PhoneShellStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PhoneBackgroundBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource PhoneCornerRadius}" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="BorderBrush" Value="{StaticResource MutedBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="MetricCardStyle" TargetType="Border">
        <Setter Property="Padding" Value="14" />
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="BorderBrush" Value="{StaticResource MutedBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
</ResourceDictionary>
