<Window x:Class="UbuntuPackageDownloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ubuntu Package Downloader" Height="860" Width="1600"
        MinHeight="760" MinWidth="1400"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="170" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Ubuntu Package Downloader" FontSize="24" FontWeight="SemiBold" />
                <TextBlock Text="Online PC에서 Offline PC Local-Repo용 .deb dependency bundle을 생성합니다."
                           Foreground="#555" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="DownloadButton" Content="Download" Width="96" Margin="6,0" Click="DownloadButton_Click" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" BorderBrush="#D8D8D8" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,10">
                    <TextBlock Text="Ubuntu Version" FontWeight="SemiBold" />
                    <ComboBox x:Name="UbuntuVersionComboBox" IsEditable="True" IsTextSearchEnabled="True" Height="28" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,10">
                    <TextBlock Text="Architecture" FontWeight="SemiBold" />
                    <ComboBox x:Name="ArchitectureComboBox" IsEditable="True" IsTextSearchEnabled="True" Height="28" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,10">
                    <TextBlock Text="Components" FontWeight="SemiBold" />
                    <ComboBox x:Name="ComponentsComboBox" Height="28" IsEditable="False" />
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,0,10">
                    <TextBlock Text="Pockets" FontWeight="SemiBold" />
                    <ComboBox x:Name="PocketsComboBox" Height="28" IsEditable="False" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,10,10">
                    <TextBlock Text="Output Folder" FontWeight="SemiBold" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="OutputFolderTextBox" Height="28" IsReadOnly="True" />
                        <Button Grid.Column="1" Content="Open Folder" Width="92" Margin="8,0,0,0"
                                Click="OpenOutputFolderButton_Click" />
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,10,10">
                    <TextBlock Text="Server Repository" FontWeight="SemiBold" />
                    <ComboBox x:Name="ServerRepositoryComboBox" Height="28" IsEditable="False" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="3" Margin="0,0,0,10">
                    <TextBlock Text="Options" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Height="28" VerticalAlignment="Center">
                        <CheckBox x:Name="IncludeRecommendsCheckBox" Content="Include Recommends" Margin="0,0,14,0" />
                        <CheckBox x:Name="SkipExistingCheckBox" Content="Skip existing" IsChecked="True" IsEnabled="False" />
                    </StackPanel>
                </StackPanel>

                <ProgressBar x:Name="ProgressBar" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" Height="8" Minimum="0" Maximum="100" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#D8D8D8" BorderThickness="1" CornerRadius="4" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Package List" FontWeight="SemiBold" DockPanel.Dock="Left" />
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button Content="Import" Width="70" Margin="4,0" Click="ImportButton_Click" />
                            <Button Content="Export" Width="70" Margin="4,0,0,0" Click="ExportButton_Click" />
                        </StackPanel>
                    </DockPanel>
                    <TextBox x:Name="PackageListTextBox" Grid.Row="1"
                             AcceptsReturn="True" AcceptsTab="False"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             Text="curl" />
                    <TextBlock Grid.Row="2" Foreground="#666" Margin="0,8,0,2"
                               TextWrapping="Wrap"
                               Text="한 줄에 하나씩 입력합니다. 예: curl 또는 curl=8.5.0-2ubuntu10.9" />
                </Grid>
            </Border>

            <Border Grid.Column="2" BorderBrush="#D8D8D8" BorderThickness="1" CornerRadius="4" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Resolved / Download Report" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <DataGrid x:Name="ReportDataGrid" Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              ItemsSource="{Binding ReportRows}">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="White" />
                                <Setter Property="Foreground" Value="#202020" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Reason}" Value="Requested">
                                        <Setter Property="Background" Value="#E8F1FF" />
                                        <Setter Property="Foreground" Value="#123F73" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Reason}" Value="Dependency">
                                        <Setter Property="Background" Value="#EAF7EE" />
                                        <Setter Property="Foreground" Value="#205B36" />
                                    </DataTrigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" />
                                        <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="No." Binding="{Binding Number}" Width="52" IsReadOnly="True" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                            <DataGridTextColumn Header="Package" Binding="{Binding Package}" Width="140" />
                            <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="180" />
                            <DataGridTextColumn Header="Arch" Binding="{Binding Architecture}" Width="80" />
                            <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="260" />
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="260" MinWidth="260" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" BorderBrush="#D8D8D8" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,12,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Log" FontWeight="SemiBold" Margin="0,0,0,8" />
                <TextBox x:Name="LogTextBox" Grid.Row="1" IsReadOnly="True" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas" />
            </Grid>
        </Border>

        <StatusBar Grid.Row="4">
            <StatusBarItem>
                <TextBlock x:Name="StatusTextBlock" Text="Ready" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
